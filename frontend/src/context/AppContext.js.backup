import React, { createContext, useContext, useState, useEffect } from 'react';
import axios from 'axios';

const AppContext = createContext();

export const api = axios.create({
  baseURL: `http://${window.location.hostname}:8000/api/`,
});

api.interceptors.request.use(config => {
  const token = sessionStorage.getItem('adminToken');
  if (token) {
    config.headers.Authorization = `Bearer ${token}`;
  }
  return config;
});

export const AppProvider = ({ children }) => {
  const [eventDetails, setEventDetails] = useState(null);
  const [bookings, setBookings] = useState([]);
  const [isLoading, setIsLoading] = useState(true);

  useEffect(() => {
    fetchEvent();
  }, []);

  const fetchEvent = async () => {
    try {
      const response = await api.get('events/');
      if (response.data && response.data.length > 0) {
        setEventDetails(response.data[0]);
      }
    } catch (error) {
      console.error('Error fetching event details', error);
    } finally {
      setIsLoading(false);
    }
  };

  const fetchAdminBookings = async () => {
    try {
      const response = await api.get('bookings/');
      setBookings(response.data);
    } catch (error) {
      console.error('Error fetching bookings', error);
      if (error.response?.status === 401) {
        sessionStorage.removeItem('adminToken');
        window.location.href = '/admin/login';
      }
    }
  };

  const getBookedSeats = () => {
    return eventDetails?.booked_seats || [];
  };

  const addBooking = async (bookingData) => {
    try {
      const payload = {
        name: bookingData.name,
        email: bookingData.email,
        phone: bookingData.phone,
        event: eventDetails.id,
        ticketsCount: bookingData.ticketsCount,
        seats: bookingData.seats,
        amount: bookingData.amount,
        utr: bookingData.utr
      };
      const response = await api.post('book/', payload);
      // Refresh event details to update booked_seats locally
      await fetchEvent();
      return response.data;
    } catch (error) {
      console.error('Error creating booking', error);
      throw error;
    }
  };

  const updateEventDetails = async (newDetails) => {
    try {
      const response = await api.put(`events/${eventDetails.id}/`, newDetails);
      setEventDetails(response.data);
      return response.data;
    } catch (error) {
      console.error('Error updating event', error);
      throw error;
    }
  };

  return (
    <AppContext.Provider value={{
      eventDetails,
      updateEventDetails,
      bookings,
      fetchAdminBookings,
      addBooking,
      getBookedSeats,
      isLoading
    }}>
      {children}
    </AppContext.Provider>
  );
};

export const useAppContext = () => useContext(AppContext);
